# Archivos de texto - normalizar line endings
*.js text eol=lf
*.jsx text eol=lf
*.json text eol=lf
*.md text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.html text eol=lf
*.css text eol=lf

# Node modules y dependencias - no procesar
node_modules/ -text
*.node binary

# Binarios
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.mov binary
*.mp4 binary
*.zip binary

# Archivos sensibles
.env* merge=union
.env.local merge=union

# Documentación
*.md text diff=markdown

# Scripts
*.sh text eol=lf
*.bat text eol=crlf
